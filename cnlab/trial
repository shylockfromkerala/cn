//gobackserver
#include<stdio.h>
#include<stdlib.h>
#include<string.h>
#include<unistd.h>
#include<arpa/inet.h>
#include<time.h>

int main()
{
    // Server socket
    int sockfd;

    // Server and client address structures
    struct sockaddr_in serverAddr, clientAddr;

    // Size of client address
    socklen_t addr_size;

    // Variables for frame and ACK
    int frame, ack;

    // Generate different random numbers every run
    srand(time(0));

    // Create UDP socket
    sockfd = socket(AF_INET,
                    SOCK_DGRAM,
                    0);

    // Configure server address
    serverAddr.sin_family = AF_INET;

    // Port number
    serverAddr.sin_port = htons(5000);

    // Accept packets from any IP
    serverAddr.sin_addr.s_addr = INADDR_ANY;

    // Bind socket with address
    bind(sockfd,
         (struct sockaddr*)&serverAddr,
         sizeof(serverAddr));

    printf("UDP Server Waiting...\n");

    // Infinite loop
    while(1)
    {
        addr_size = sizeof(clientAddr);

        // Receive frame from client
        int n = recvfrom(sockfd,
                         &frame,
                         sizeof(int),
                         0,
                         (struct sockaddr*)&clientAddr,
                         &addr_size);

        // If error occurs
        if(n <= 0)
        {
            continue;
        }

        // Print received frame
        printf("\n[SERVER] Frame %d Received\n",
                frame);

        // Random number for ACK loss simulation
        int random = rand() % 100;

        // 80% chance ACK is sent
        if(random < 80)
        {
            // ACK = next expected frame
            ack = frame + 1;

            // Send ACK to client
            sendto(sockfd,
                   &ack,
                   sizeof(int),
                   0,
                   (struct sockaddr*)&clientAddr,
                   addr_size);

            printf("[SERVER] ACK %d Sent\n",
                    ack);
        }
        else
        {
            // Simulate ACK loss
            printf("[SERVER] ACK Lost\n");
        }
    }

    // Close socket
    close(sockfd);

    return 0;
}




//gobacknclient
#include<stdio.h>
#include<stdlib.h>
#include<string.h>
#include<unistd.h>
#include<arpa/inet.h>
#include<sys/select.h>
#include<time.h>

int main()
{
    // Client socket
    int sockfd;

    // Server address structure
    struct sockaddr_in serverAddr;

    // Size of address structure
    socklen_t addr_size;

    // First unacknowledged frame
    int base = 0;

    // Sliding window size
    int window_size = 4;

    // Total frames
    int total_frames;

    // Loop variable and ACK
    int i, ack;

    // For select()
    fd_set readfds;

    // Timeout structure
    struct timeval tv;

    // Generate different random values every run
    srand(time(0));

    // Create UDP socket
    sockfd = socket(AF_INET,
                    SOCK_DGRAM,
                    0);

    // Configure server address
    serverAddr.sin_family = AF_INET;

    // Port number
    serverAddr.sin_port = htons(5000);

    // Localhost IP
    serverAddr.sin_addr.s_addr =
            inet_addr("127.0.0.1");

    addr_size = sizeof(serverAddr);

    // Input total frames
    printf("Enter Total Frames : ");

    scanf("%d", &total_frames);

    // Continue until all frames are acknowledged
    while(base < total_frames)
    {
        printf("\nSending Window : ");

        // Send frames inside current window
        for(i = base;
            i < base + window_size &&
            i < total_frames;
            i++)
        {
            // Random number for frame loss simulation
            int random = rand() % 100;

            // 80% chance frame is sent
            if(random < 80)
            {
                // Send frame to server
                sendto(sockfd,
                       &i,
                       sizeof(int),
                       0,
                       (struct sockaddr*)&serverAddr,
                       addr_size);

                printf("%d Sent  ", i);
            }
            else
            {
                // Simulate frame loss
                printf("%d Lost  ", i);
            }
        }

        // Clear descriptor set
        FD_ZERO(&readfds);

        // Add socket to descriptor set
        FD_SET(sockfd, &readfds);

        // Timeout = 3 seconds
        tv.tv_sec = 3;

        tv.tv_usec = 0;

        // Wait for ACK
        int activity = select(sockfd + 1,
                              &readfds,
                              NULL,
                              NULL,
                              &tv);

        // ACK received
        if(activity > 0)
        {
            // Receive ACK
            recvfrom(sockfd,
                     &ack,
                     sizeof(int),
                     0,
                     NULL,
                     NULL);

            printf("\nACK %d Received\n",
                    ack);

            // Slide window
            base = ack;
        }
        else
        {
            // Timeout occurred
            printf("\nTimeout...\n");

            // Retransmit from base
            printf("Retransmitting from Frame %d\n",
                    base);
        }
    }

    printf("\nAll Frames Sent Successfully\n");

    // Close socket
    close(sockfd);

    return 0;
}